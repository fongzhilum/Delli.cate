{
  "manifest_version": 3,
  "name": "Delli.cate Monitor",
  "version": "2.0.0",
  "description": "Youth welfare monitoring — reads Instagram story text for distress signals.",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://www.instagram.com/*",
    "https://*.supabase.co/*",
    "https://generativelanguage.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}
